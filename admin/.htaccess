Options -Indexes

# Блокуємо прямий доступ до внутрішніх директорій
<FilesMatch "\.(php)$">
  <If "%{REQUEST_URI} =~ m#/(config|db|enums|ui)/#">
    Order Allow,Deny
    Deny from all
  </If>
</FilesMatch>

# Security headers
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "same-origin"
</IfModule>
